generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id       String   @id @default(cuid()) // or uuid() if you prefer
  name     String
  email    String   @unique
  password String
} 

model ClothingImage {
  id        Int      @id @default(autoincrement())
  filename  String
  mimetype  String
  imageData Bytes
  category  String  
  createdAt DateTime @default(now())
}

model ClothingItem {
  id          Int      @id @default(autoincrement())
  category    String
  imageBytes  Bytes
  createdAt   DateTime @default(now())
}

