datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}


enum Category {
  HOODIE
  PANTS
  SHORTS
  SHIRT
  SHOES
}

model Clothing {
  id        Int      @id @default(autoincrement())
  imagePath String
  category  Category
  createdAt DateTime @default(now())
}
